{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/events/dfm.issue.identified.v1.schema.json",
  "title": "DFM问题识别事件",
  "type": "object",
  "required": ["metadata", "payload"],
  "additionalProperties": false,
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["identity", "context"],
      "properties": {
        "identity": {
          "type": "object",
          "required": ["event_id", "event_type", "version"],
          "properties": {
            "event_id": {"type": "string", "format": "uuid"},
            "event_type": {"type": "string", "const": "dfm.issue.identified"},
            "version": {"type": "integer", "const": 1}
          }
        },
        "context": {
          "type": "object",
          "required": ["timestamp", "source", "producer", "trace_id", "tenant_id"],
          "properties": {
            "timestamp": {"type": "string", "format": "date-time"},
            "source": {"type": "string", "const": "manufacturability"},
            "producer": {"type": "string"},
            "correlation_id": {"type": "string"},
            "causation_id": {"type": "string"},
            "trace_id": {"type": "string"},
            "tenant_id": {"type": "string"},
            "user_id": {"type": "string"}
          }
        }
      }
    }
  },
  "properties": {
    "metadata": {"$ref": "#/definitions/metadata"},
    "payload": {
      "type": "object",
      "required": ["issue_id", "report_id", "severity", "description"],
      "properties": {
        "issue_id": {"type": "string"},
        "report_id": {"type": "string"},
        "severity": {"type": "string", "enum": ["critical", "major", "minor"]},
        "description": {"type": "string"},
        "assigned_to": {"type": "string"}
      }
    }
  }
}
