{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/events/plan.stage_advanced.v1.schema.json",
  "title": "策划阶段推进事件",
  "description": "当 ProductPlan 从一个阶段推进到下一阶段时发射。",
  "type": "object",
  "required": ["event_id", "event_type", "version", "timestamp", "source", "payload"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_type": {"type": "string", "const": "plan.stage_advanced"},
    "version": {"type": "integer", "const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "source": {"type": "string", "const": "planning"},
    "trace_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "payload": {
      "type": "object",
      "required": ["plan_id", "from_stage", "to_stage", "triggered_by"],
      "properties": {
        "plan_id": {"type": "string", "format": "uuid"},
        "from_stage": {
          "type": "string",
          "enum": ["draft","competitor","definition","costing","tech_input","project_init","approved","released"]
        },
        "to_stage": {
          "type": "string",
          "enum": ["competitor","definition","costing","tech_input","project_init","approved","released"]
        },
        "triggered_by": {"type": "string"},
        "comment": {"type": "string"},
        "met_requirements": {
          "type": "array", "items": {"type": "string"},
          "description": "该阶段满足的前置条件列表"
        },
        "unmet_requirements": {
          "type": "array", "items": {"type": "string"},
          "description": "未满足的条件（如有 Waiver）"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "user_id": {"type": "string"},
        "correlation_id": {"type": "string", "format": "uuid"}
      }
    }
  }
}
