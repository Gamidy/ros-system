{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cert.sample.submitted.v1.schema.json",
  "title": "Cert Sample Submitted",
  "description": "Emitted when a sample is submitted for certification testing.",
  "type": "object",
  "required": ["metadata", "payload"],
  "additionalProperties": false,
  "metadata": {
    "type": "object",
    "required": ["identity", "context"],
    "additionalProperties": false,
    "properties": {
      "identity": {
        "type": "object",
        "required": ["event_id", "event_type", "version"],
        "additionalProperties": false,
        "properties": {
          "event_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this event instance."
          },
          "event_type": {
            "type": "string",
            "const": "cert.sample.submitted",
            "description": "Event type identifier."
          },
          "version": {
            "type": "integer",
            "const": 1,
            "description": "Schema version."
          }
        }
      },
      "context": {
        "type": "object",
        "required": [
          "timestamp",
          "source",
          "producer",
          "correlation_id",
          "causation_id",
          "trace_id",
          "tenant_id",
          "user_id"
        ],
        "additionalProperties": false,
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the event was produced."
          },
          "source": {
            "type": "string",
            "const": "verification",
            "description": "System domain that emitted the event."
          },
          "producer": {
            "type": "string",
            "description": "Service or component that produced the event."
          },
          "correlation_id": {
            "type": "string",
            "format": "uuid",
            "description": "Correlation identifier linking related events."
          },
          "causation_id": {
            "type": "string",
            "format": "uuid",
            "description": "Identifier of the event that caused this event."
          },
          "trace_id": {
            "type": "string",
            "format": "uuid",
            "description": "Distributed trace identifier."
          },
          "tenant_id": {
            "type": "string",
            "description": "Tenant / organisation identifier."
          },
          "user_id": {
            "type": "string",
            "description": "User who triggered the event."
          }
        }
      }
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "payload": {
      "type": "object",
      "required": [
        "sample_id",
        "cert_project_id",
        "sample_type",
        "submitted_at"
      ],
      "additionalProperties": false,
      "properties": {
        "sample_id": {
          "type": "string",
          "description": "Unique identifier for the sample."
        },
        "cert_project_id": {
          "type": "string",
          "description": "Identifier of the associated certification project."
        },
        "sample_type": {
          "type": "string",
          "description": "Type of sample (e.g. prototype, production sample, etc.)."
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of sample submission."
        },
        "lab": {
          "type": "string",
          "description": "Testing laboratory name or identifier."
        },
        "sample_count": {
          "type": "integer",
          "description": "Number of units submitted.",
          "minimum": 1,
          "default": 1
        },
        "remark": {
          "type": "string",
          "description": "Additional remarks or notes for this sample submission."
        },
        "submitted_by": {
          "type": "string",
          "description": "User or system that submitted the sample."
        }
      }
    }
  },
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["identity", "context"],
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "object",
          "required": ["event_id", "event_type", "version"],
          "additionalProperties": false,
          "properties": {
            "event_id": {
              "type": "string",
              "format": "uuid",
              "description": "Unique identifier for this event instance."
            },
            "event_type": {
              "type": "string",
              "const": "cert.sample.submitted",
              "description": "Event type identifier."
            },
            "version": {
              "type": "integer",
              "const": 1,
              "description": "Schema version."
            }
          }
        },
        "context": {
          "type": "object",
          "required": [
            "timestamp",
            "source",
            "producer",
            "correlation_id",
            "causation_id",
            "trace_id",
            "tenant_id",
            "user_id"
          ],
          "additionalProperties": false,
          "properties": {
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp when the event was produced."
            },
            "source": {
              "type": "string",
              "const": "verification",
              "description": "System domain that emitted the event."
            },
            "producer": {
              "type": "string",
              "description": "Service or component that produced the event."
            },
            "correlation_id": {
              "type": "string",
              "format": "uuid",
              "description": "Correlation identifier linking related events."
            },
            "causation_id": {
              "type": "string",
              "format": "uuid",
              "description": "Identifier of the event that caused this event."
            },
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "Distributed trace identifier."
            },
            "tenant_id": {
              "type": "string",
              "description": "Tenant / organisation identifier."
            },
            "user_id": {
              "type": "string",
              "description": "User who triggered the event."
            }
          }
        }
      }
    }
  }
}
