{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/events/dfm.report.created.v1.schema.json",
  "title": "DFM报告创建事件",
  "description": "当创建DFM分析报告时触发。",
  "type": "object",
  "required": ["metadata", "payload"],
  "additionalProperties": false,
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["identity", "context"],
      "properties": {
        "identity": {
          "type": "object",
          "required": ["event_id", "event_type", "version"],
          "properties": {
            "event_id": {"type": "string", "format": "uuid"},
            "event_type": {"type": "string", "const": "dfm.report.created"},
            "version": {"type": "integer", "const": 1}
          }
        },
        "context": {
          "type": "object",
          "required": ["timestamp", "source", "producer", "trace_id", "tenant_id"],
          "properties": {
            "timestamp": {"type": "string", "format": "date-time"},
            "source": {"type": "string", "const": "manufacturability"},
            "producer": {"type": "string"},
            "correlation_id": {"type": "string", "format": "uuid"},
            "causation_id": {"type": "string"},
            "trace_id": {"type": "string"},
            "tenant_id": {"type": "string"},
            "user_id": {"type": "string"}
          }
        }
      }
    }
  },
  "properties": {
    "metadata": {"$ref": "#/definitions/metadata"},
    "payload": {
      "type": "object",
      "required": ["report_id", "project_id", "report_no", "created_by"],
      "additionalProperties": false,
      "properties": {
        "report_id": {"type": "string", "description": "DFM报告ID"},
        "project_id": {"type": "string", "description": "关联项目ID"},
        "report_no": {"type": "string", "description": "报告编号"},
        "created_by": {"type": "string", "description": "创建人"}
      }
    }
  }
}
