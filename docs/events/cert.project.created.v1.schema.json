              "format": "uuid",
              "description": "Unique identifier for this event instance."
            },
            "event_type": {
              "type": "string",
              "const": "cert.project.created",
              "description": "Event type identifier."
            },
            "version": {
              "type": "integer",
              "const": 1,
              "description": "Schema version."
            }
          }
        },
        "context": {
          "type": "object",
          "required": [
            "timestamp",
            "source",
            "producer",
            "correlation_id",
            "causation_id",
            "trace_id",
            "tenant_id",
            "user_id"
          ],
          "additionalProperties": false,
          "properties": {
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp when the event was produced."
            },
            "source": {
              "type": "string",
              "const": "verification",
              "description": "System domain that emitted the event."
            },
            "producer": {
              "type": "string",
              "description": "Service or component that produced the event."
            },
            "correlation_id": {
              "type": "string",
              "format": "uuid",
              "description": "Correlation identifier linking related events."
            },
            "causation_id": {
              "type": "string",
              "format": "uuid",
              "description": "Identifier of the event that caused this event."
            },
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "Distributed trace identifier."
            },
            "tenant_id": {
              "type": "string",
              "description": "Tenant / organisation identifier."
            },
            "user_id": {
              "type": "string",
              "description": "User who triggered the event."
            }
          }
        }
      }
    }
  }
}
