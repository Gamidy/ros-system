# ============================================================================
# ROS 系统环境变量配置模板
# ============================================================================
# 使用方法:
#   开发环境: cp .env.template .env.development
#   生产环境: cp .env.template .env.production
#   或者直接设置环境变量（优先级最高）
#
# 配置优先级: 环境变量 > .env.{ENV} > .env > 默认值
# ============================================================================

# ── 环境标识 ──
# ENV=development    # 开发环境
# ENV=production     # 生产环境

# ── 数据库 ──
# DB_TYPE=mysql                        # sqlite | mysql
# DATABASE_URL=                        # 完整数据库URL（设置后覆盖其他DB_*配置）
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password_here
# DB_NAME=ros

# ── Redis / Celery ──
# REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ──
# JWT_SECRET_KEY=your-256-bit-secret

# ── CORS ──
# CORS_ORIGINS=["http://localhost:3000","http://139.196.15.52"]

# ── 服务器 ──
# HOST=0.0.0.0
# PORT=8000

# ── 调试 ──
# DEBUG=false
